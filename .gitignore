# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Test, lint, and coverage caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling and local workspace caches
.cache/
.apptainer-cache/
.claude/

# Downloaded model weights/checkpoints must stay out of Git
*.pth
*.pt
*.ckpt
*.safetensors
third_party/window/**/weights/
third_party/window/**/checkpoints/
third_party/window/**/.cache/
third_party/window/**/*.so

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Pipeline runtime outputs
out/
output/
results/
results_debug/
results_overlay_test/

data/

# Generated logs and temporary diagnostics
*.log
*.tmp

# Apptainer images and Docker archives built locally
*.sif
*.tar
