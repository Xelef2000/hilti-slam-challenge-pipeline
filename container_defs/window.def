Bootstrap: docker
From: ubuntu:24.04

%environment
    export DEBIAN_FRONTEND=noninteractive
    export MPLBACKEND=Agg
    export PYTHONDONTWRITEBYTECODE=1

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        python3.12 \
        python3.12-dev \
        python3.12-venv \
        python3-pip \
        libglib2.0-0 \
        libgl1 \
        libgomp1 \
        libsm6 \
        libxext6 \
        libxrender1 \
        libstdc++6 \
        libjpeg-turbo8 \
        libpng16-16 \
        libopenblas0-pthread \
        && apt-get clean && rm -rf /var/lib/apt/lists/*
    python3.12 -m venv /opt/window_venv
    /opt/window_venv/bin/python -m pip install --upgrade pip setuptools wheel
    /opt/window_venv/bin/python -m pip install --index-url https://download.pytorch.org/whl/cpu torch torchvision
    /opt/window_venv/bin/python -m pip install \
        'numpy>=1.26,<2' \
        opencv-python-headless \
        matplotlib \
        pillow \
        scipy \
        huggingface_hub \
        transformers==4.57.1 \
        'timm>=1.0.17' \
        addict \
        yapf \
        'supervision>=0.22.0' \
        pycocotools \
        'ftfy==6.1.1' \
        regex \
        'iopath>=0.1.10' \
        einops \
        triton \
        psutil \
        typing_extensions \
        tqdm \
        setuptools
    rm -rf /root/.cache/pip
    mkdir -p /workspace
