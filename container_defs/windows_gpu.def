Bootstrap: docker
From: pytorch/pytorch:2.7.0-cuda12.8-cudnn9-devel

%files
    third_party/windows_pipeline /opt/windows_pipeline

%environment
    export DEBIAN_FRONTEND=noninteractive
    export CUDA_HOME=/usr/local/cuda
    export TORCH_CUDA_ARCH_LIST="6.0 6.1 7.0 7.5 8.0 8.6 9.0 12.0+PTX"
    export SETUPTOOLS_USE_DISTUTILS=stdlib
    export PIP_NO_CACHE_DIR=1

%post
    export DEBIAN_FRONTEND=noninteractive
    export CUDA_HOME=/usr/local/cuda
    export TORCH_CUDA_ARCH_LIST="6.0 6.1 7.0 7.5 8.0 8.6 9.0 12.0+PTX"
    export SETUPTOOLS_USE_DISTUTILS=stdlib
    export PIP_NO_CACHE_DIR=1

    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        libglib2.0-0 \
        wget \
        && rm -rf /var/lib/apt/lists/*

    python -m pip install --upgrade pip 'setuptools<81' wheel
    python -m pip install torch==2.7.0 torchvision==0.22.0 --index-url https://download.pytorch.org/whl/cu128
    python -m pip install \
        addict \
        einops \
        ftfy==6.1.1 \
        huggingface_hub \
        'iopath>=0.1.10' \
        matplotlib \
        'numpy>=1.26,<2' \
        opencv-python-headless \
        pillow \
        pycocotools \
        psutil \
        regex \
        scipy \
        supervision \
        'timm>=1.0.17' \
        triton \
        transformers==4.45.2 \
        tqdm \
        typing_extensions \
        yapf

    python - <<'PY'
from pathlib import Path
from urllib.request import urlretrieve

checkpoint = Path("/opt/windows_pipeline/GroundingDINO/weights/groundingdino_swint_ogc.pth")
checkpoint.parent.mkdir(parents=True, exist_ok=True)
if not checkpoint.exists():
    urlretrieve(
        "https://github.com/IDEA-Research/GroundingDINO/releases/download/"
        "v0.1.0-alpha/groundingdino_swint_ogc.pth",
        checkpoint,
    )
PY

    python -m pip install --no-build-isolation --no-deps /opt/windows_pipeline/GroundingDINO
    python -m pip install --no-build-isolation --no-deps /opt/windows_pipeline/sam3
    python -m pip uninstall -y opencv-python opencv-contrib-python opencv-contrib-python-headless
    python -m pip install --force-reinstall --no-deps opencv-python-headless==4.11.0.86
    mkdir -p /workspace
